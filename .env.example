# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URLs
NEXT_PUBLIC_HUB_URL=http://localhost:3000
NEXT_PUBLIC_CLIENT_URL=http://localhost:3001

# Pennylane
# URL unique pour sandbox et prod (même infra Pennylane)
# Le sandbox = société de test distincte, token différent par société
PENNYLANE_API_URL=https://app.pennylane.com/api/external/v2
PENNYLANE_API_TOKEN=your-pennylane-api-token-here

# Google OAuth (Calendar, Gmail, Drive, Meet) — même client OAuth pour tous les services
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs > MonProjetPro Hub
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Meet API — refresh token du compte MiKL (généré via OAuth Playground)
# Scopes requis : meetings.space.created, meetings.space.readonly, calendar
GOOGLE_MEET_REFRESH_TOKEN=
